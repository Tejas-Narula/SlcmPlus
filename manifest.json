{
  "manifest_version": 3,
  "name": "SlcmPlus",
  "version": "1.1",
  "description": "Improves the workflow and provide incredible and neccary insights for MUJ`s students",

  "content_scripts": [
    {
      "matches": [
        "https://mujslcm.jaipur.manipal.edu/Student/Academic/AttendanceSummaryForStudent",
